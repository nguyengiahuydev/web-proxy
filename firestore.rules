rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - balance: number (required, non-negative)
    //   - discount: number (optional, 0-100)
    //   - createdAt: timestamp (required)
    //
    // Collection: transactions
    // Document ID: transactionId
    // Fields:
    //   - userId: string (required, matches auth.uid)
    //   - amount: number (required)
    //   - type: string (required, 'deposit' or 'purchase')
    //   - status: string (required, 'pending', 'success', 'failed')
    //   - description: string
    //   - createdAt: timestamp (required)
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'balance', 'createdAt']) &&
             data.uid == userId &&
             data.balance is number && data.balance >= 0 &&
             (!('discount' in data) || (data.discount is number && data.discount >= 0 && data.discount <= 100));
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'status', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['deposit', 'purchase'] &&
             data.status in ['pending', 'success', 'failed'];
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data, userId);
      allow update: if (isOwner(userId) && isValidUser(request.resource.data, userId) && 
                    request.resource.data.balance == resource.data.balance) || isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }

    match /transactions/{transactionId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAdmin(); // Admin can update status
      allow delete: if false;
    }

    match /proxies/{proxyId} {
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isAdmin(); // Only admin/backend can create proxies
      allow update: if isAdmin();
      allow delete: if false;
    }

    // Admin access (for demo purposes, using user email from context)
    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == "huynofa@gmail.com";
    }

    match /users/{userId} {
      allow update: if isAdmin();
    }
  }
}
